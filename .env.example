# ============================================================
# Music Manager — Environment Configuration Example
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# --- Application -------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
SECRET_KEY=
# Session lifetime in seconds (default: 12 hours).
SESSION_TTL_SECONDS=43200
# The documented direct LAN HTTP setup requires false. Set true whenever the
# application is served behind HTTPS so session and CSRF cookies are Secure.
AUTH_COOKIE_SECURE=false

# --- Database ----------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/music_manager.db

# --- Library Naming ----------------------------------------------
# Template tokens: {album_artist} {year} {album} {disc_track} {title} {ext}
NAMING_TEMPLATE={album_artist}/{year} - {album}/{disc_track} - {title}.{ext}
LIBRARY_ROOT=/music
STAGING_ROOT=/staging/music-manager

# --- slskd -------------------------------------------------------
SLSKD_URL=
SLSKD_API_KEY=

# --- Prowlarr ----------------------------------------------------
PROWLARR_URL=
PROWLARR_API_KEY=

# --- SABnzbd -----------------------------------------------------
SABNZBD_URL=
SABNZBD_API_KEY=

# --- YouTube (yt-dlp) --------------------------------------------
# No API key required; set cookies file path if needed for age-restricted content
YTDLP_COOKIES_FILE=

# --- TIDAL-DL backend -------------------------------------------
# Disabled by default. Enable only after an operator-installed, authenticated
# Tidal-DL backend is running and writes completed files under STAGING_ROOT.
TIDAL_ENABLED=false
# HTTP backend URL for health/search/enqueue if using a wrapper service.
TIDAL_BACKEND_URL=
# Local executable or wrapper path if using a host/container-mounted CLI backend.
TIDAL_BACKEND_PATH=
# Output directory configured in Tidal-DL; must be under STAGING_ROOT.
TIDAL_STAGING_DIR=

# --- MusicBrainz -------------------------------------------------
MUSICBRAINZ_APP_NAME=music-manager
MUSICBRAINZ_APP_VERSION=0.1.3
MUSICBRAINZ_CONTACT=

# --- Deezer ------------------------------------------------------
# Public API — no key required for metadata lookups
# Set if using a private/partner API endpoint
DEEZER_API_URL=https://api.deezer.com

# --- AcoustID ----------------------------------------------------
# Optional: leave blank to disable cloud fingerprint lookup.
# fpcalc must be available in PATH for local fingerprinting regardless.
ACOUSTID_API_KEY=

# --- Logging -----------------------------------------------------
LOG_LEVEL=INFO
